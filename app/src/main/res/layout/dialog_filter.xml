<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Заголовок диалога -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Фильтрация записей"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выберите параметры для фильтрации"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp"/>

        <!-- Секция: Фильтр по настроению -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 Настроение"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <RadioGroup
            android:id="@+id/rgMoodFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/rbFilterMood0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="😡 Ужасное настроение"
                android:textSize="15sp"
                android:paddingVertical="8dp"
                android:buttonTint="?attr/colorPrimary"/>

            <RadioButton
                android:id="@+id/rbFilterMood1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="😢 Плохое настроение"
                android:textSize="15sp"
                android:paddingVertical="8dp"
                android:buttonTint="?attr/colorPrimary"/>

            <RadioButton
                android:id="@+id/rbFilterMood2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="😐 Нейтральное настроение"
                android:textSize="15sp"
                android:paddingVertical="8dp"
                android:buttonTint="?attr/colorPrimary"/>

            <RadioButton
                android:id="@+id/rbFilterMood3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🙂 Хорошее настроение"
                android:textSize="15sp"
                android:paddingVertical="8dp"
                android:buttonTint="?attr/colorPrimary"/>

            <RadioButton
                android:id="@+id/rbFilterMood4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="😍 Отличное настроение"
                android:textSize="15sp"
                android:paddingVertical="8dp"
                android:buttonTint="?attr/colorPrimary"/>

        </RadioGroup>

        <!-- Разделитель -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginBottom="24dp"/>

        <!-- Секция: Фильтр по дате -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 Период"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выберите диапазон дат (необязательно)"
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartDate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📅 Дата начала"
            android:textSize="15sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="12dp"
            app:cornerRadius="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEndDate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📅 Дата окончания"
            android:textSize="15sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="24dp"
            app:cornerRadius="8dp"/>

        <!-- Индикатор активных фильтров -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍 Активные фильтры"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvActiveFilters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Фильтры не применены"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Кнопки управления -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:text="Сбросить всё"
                android:textSize="15sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_marginEnd="8dp"
                app:cornerRadius="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApply"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:text="Применить фильтры"
                android:textSize="15sp"
                android:paddingHorizontal="24dp"
                app:cornerRadius="8dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>